{
  "expo": {
    "name": "BuFu",
    "slug": "estatelance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bufu-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/bufu-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1356"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.bufu.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Manzil tanlash uchun joylashuv ruxsati kerak.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Manzil tanlash uchun joylashuv ruxsati kerak.",
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "yandexmaps",
          "dgis",
          "maps"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bufu-logo.png",
        "backgroundColor": "#1e1356"
      },
      "package": "uz.bufu.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/bufu-logo.png",
          "color": "#6366f1",
          "defaultChannel": "bufu-default",
          "sounds": ["./assets/notification.wav"]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Manzil tanlash uchun joylashuv ruxsati kerak."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kompaniya rasmi yuklash uchun galereya ruxsati kerak."
        }
      ]
    ],
    "scheme": "bufu",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee690488-e7f7-4d8c-ad9f-aeb8b068512d"
      }
    }
  }
}
