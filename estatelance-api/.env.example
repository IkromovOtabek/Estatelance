# ============================================================
# EstateLance / BuFu API — Environment Variables (namuna)
# Bu faylni `.env` ga nusxalang va qiymatlarni to'ldiring.
# ============================================================

# ── Server ────────────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development
PORT=3007

# ── Database (MongoDB) ─────────────────────────────────────────────────────────
# Kod avvalo MONGODB_URI ni o'qiydi; bo'lmasa NODE_ENV ga qarab
# MONGO_DEV (development) yoki MONGO_PROD (production) ni ishlatadi.
# Eng oddiy variant — faqat MONGODB_URI ni belgilash:
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/Freelance
# Yoki muhitga qarab alohida:
# MONGO_DEV=mongodb://localhost:27017/bufu
# MONGO_PROD=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/Freelance

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long

# ── CORS ──────────────────────────────────────────────────────────────────────
# Vergul bilan ajratilgan, probelsiz. Production:
# ALLOWED_ORIGINS=https://bufu.uz,https://www.bufu.uz
ALLOWED_ORIGINS=http://localhost:3001

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_NAME=your_bot_name
# Webhook uchun common HTTPS domen (production)
API_BASE_URL=https://api.bufu.uz

# ── AI (Google Gemini — ixtiyoriy) ─────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── File upload ────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads

# ── Google OAuth2 ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Lokal: http://localhost:3007/auth/google/callback
# Production: https://api.bufu.uz/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3007/auth/google/callback

# ── Boost bevosita to'lov (ish elonini Top ga chiqarish) ─────────────────────
PLATFORM_PAYMENT_CARD=8600 0000 0000 0000
PLATFORM_PAYMENT_PHONE=+998 90 000 00 00
PLATFORM_PAYMENT_HOLDER=BuFu
PLATFORM_PAYMENT_NOTE=To'lov izohiga ish sarlavhasini yozing.

# ── Frontend URL (Google login'dan keyin redirect) ─────────────────────────────
# Lokal: http://localhost:3001 | Production: https://bufu.uz
FRONTEND_URL=http://localhost:3001
