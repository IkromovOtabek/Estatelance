{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/estatelance-api/src",
  "monorepo": true,
  "root": "apps/estatelance-api",
  "compilerOptions": {
    "tsConfigPath": "apps/estatelance-api/tsconfig.app.json",
    "webpack": false,
    "deleteOutDir": true
  },
  "projects": {
    "estatelance-api": {
      "type": "application",
      "root": "apps/estatelance-api",
      "entryFile": "main",
      "sourceRoot": "apps/estatelance-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/estatelance-api/tsconfig.app.json"
      }
    }
  }
}
