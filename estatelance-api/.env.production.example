# ============================================================
# BuFu API — PRODUCTION .env (VPS uchun)
# Foydalanish: shu faylni VPS'da `.env` ga nusxalang va
#   <...> joylarni rotate qilingan yangi kalitlar bilan to'ldiring.
# ============================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3007

# ── Database (MongoDB) ─────────────────────────────────────────────────────────
# Parolni o'zgartirmaganingiz uchun mavjud connection string'ni qo'ying:
MONGO_PROD=mongodb+srv://Owen:<MONGO_PAROL>@owen.wkad1hh.mongodb.net/Freelance

# ── Auth ──────────────────────────────────────────────────────────────────────
# Yangi yarating: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<YANGI_64_BAYTLI_SECRET>

# ── CORS (frontend domenlari, probelsiz) ───────────────────────────────────────
ALLOWED_ORIGINS=https://bufu.uz,https://www.bufu.uz

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# @BotFather'dan yangi token oling (eskisi suhbatda ko'rindi):
TELEGRAM_BOT_TOKEN=<YANGI_TELEGRAM_TOKEN>
TELEGRAM_BOT_NAME=buildfuture_bot
API_BASE_URL=https://api.bufu.uz

# ── AI (Google Gemini — ixtiyoriy) ─────────────────────────────────────────────
GEMINI_API_KEY=<YANGI_GEMINI_KEY>

# ── File upload ────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads

# ── Google OAuth2 ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YANGI_GOOGLE_SECRET>
GOOGLE_CALLBACK_URL=https://api.bufu.uz/auth/google/callback

# ── Frontend URL (Google login'dan keyin redirect) ─────────────────────────────
FRONTEND_URL=https://bufu.uz
