# ============================================================
# BuFu Frontend (Next.js) — PRODUCTION .env.local (VPS uchun)
# Foydalanish: shu faylni `.env.local` ga nusxalang va
#   <...> joylarni rotate qilingan kalitlar bilan to'ldiring.
# ============================================================

# Backend GraphQL (server-side proxy /api/graphql ishlatadi)
GRAPHQL_SERVER_URL=https://api.bufu.uz/graphql

# Backend bazasi (WebSocket/ChatWidget, socket.io uchun)
NEXT_PUBLIC_API_URL=https://api.bufu.uz/graphql

# Telegram bot
NEXT_PUBLIC_TELEGRAM_BOT_NAME=buildfuture_bot
NEXT_PUBLIC_TELEGRAM_BOT_ID=8501731906

# Google Gemini (AI Matchmaker sahifasi) — yangi key qo'ying
NEXT_PUBLIC_GEMINI_API_KEY=<YANGI_GEMINI_KEY>

# Yandex Maps
NEXT_PUBLIC_YANDEX_MAPS_KEY=<YANDEX_MAPS_KEY>

# Google OAuth backend URL
NEXT_PUBLIC_GOOGLE_AUTH_URL=https://api.bufu.uz/auth/google

# AI chat (server-side /api/ai-chat ishlatadi) — yangi key qo'ying
OPENROUTER_API_KEY=<YANGI_OPENROUTER_KEY>
GROQ_API_KEY=<YANGI_GROQ_KEY>
