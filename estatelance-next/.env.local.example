# ============================================================
# EstateLance Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# URL of your NestJS backend GraphQL endpoint
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3007/graphql

# Your Telegram bot username (without the @ sign)
# The frontend uses this to show the Telegram Login Widget
NEXT_PUBLIC_TELEGRAM_BOT_NAME=your_bot_username

# Google Gemini API Key (for the AI Matchmaker page)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
