# ── GraphQL ───────────────────────────────────────────────────────────────────
# Internal server URL (used by Next.js server-side proxy)
GRAPHQL_SERVER_URL=http://localhost:3007/graphql

# Public API URL (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:3007/graphql

# ── Telegram ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TELEGRAM_BOT_NAME=@buildfuture_bot
